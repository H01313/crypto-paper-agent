name: Crypto Agent ✅
on: [workflow_dispatch]
jobs:
  trade:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v4
    - name: List ALL files first
      run: ls -la
    - name: Run agent
      run: |
        ls -la main.py || echo "❌ main.py MISSING!"
        python3 main.py
    - name: Verify logs
    - name: Upload logs als artifact
      uses: actions/upload-artifact@v4
      with:
        name: btc-trades
        path: logs.json
      run: |
        ls -la logs.json
        cat logs.json
