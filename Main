#!/usr/bin/env python3
print("=== LINE 1: START ===")
import sys
print("=== LINE 3: SYS OK ===")

try:
    with open('test.txt', 'w') as f:
        f.write("test")
    print("=== LINE 8: FILE WRITE OK ===")
except Exception as e:
    print(f"=== LINE 10: FILE ERROR {e} ===")
    sys.exit(1)

print("=== LINE 12: JSON TEST ===")
import json
test_json = {"test": "ok"}
print(json.dumps(test_json))
print("=== LINE 16: JSON OK ===")

print("=== LINE 18: TIME TEST ===")
from datetime import datetime
print(datetime.now().isoformat())
print("=== LINE 21: TIME OK ===")

print("=== LINE 23: RSI CALC TEST ===")
def calculate_rsi(prices):
    deltas = [prices[i] - prices[i-1] for i in range(1, len(prices))]
    print(f"Deltas: {deltas}")
    return 35.5

prices = [65000, 65200, 64800]
rsi = calculate_rsi(prices)
print(f"RSI: {rsi}")

print("=== LINE 33: TRADE JSON ===")
trade = {
    "timestamp": datetime.now().isoformat(),
    "symbol": "BTC/USDT",
    "rsi": float(rsi),
    "action": "buy",
    "simulation": True
}
print(json.dumps(trade, indent=2))

print("=== LINE 44: FINAL WRITE ===")
with open('logs.json', 'w') as f:
    json.dump([trade], f)
print("=== LINE 48: ✅ 100% SUCCESS ===")
