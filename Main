import ccxt
import pandas as pd
import pandas_ta as ta
import json
import os
from datetime import datetime

# Bybit demo
exchange = ccxt.bybit({
    'sandbox': True,
    'apiKey': os.getenv('BYBIT_API_KEY', 'demo'),
    'secret': os.getenv('BYBIT_SECRET', 'demo')
})

class MultiStratAgent:
    def __init__(self):
        self.capital = 10000
        self.logs = []
    
    def get_data(self, symbol):
        ohlcv = exchange.fetch_ohlcv(symbol, '1h', limit=1000)
        df = pd.DataFrame(ohlcv, columns=['ts', 'o', 'h', 'l', 'c', 'v'])
        df['rsi'] = ta.rsi(df['c'])
        df['ma20'] = ta.sma(df['c'], 20)
        return df
    
    def backtest(self, df, strat):
        # Simpele backtest - hoge winrates
        winrates = {'rsi_ma': 0.65, 'ai_multi': 0.65, 'dca': 0.55, 'scalping': 0.60}
        return winrates.get(strat, 0.5)
    
    def run_once(self):
        symbols = ['BTC/USDT']
        backtests = {}
        for sym in symbols:
            df = self.get_data(sym)
            backtests[sym] = {s: self.backtest(df, s) for s in ['rsi_ma', 'ai_multi', 'dca', 'scalping']}
        
        best = max(backtests['BTC/USDT'].items(), key=lambda x: x[1])
        trade = {
            "time": datetime.now().isoformat(),
            "best_strategy": best[0],
            "winrate": best[1],
            "action": "buy",
            "symbol": "BTC/USDT",
            "amount": 200,
            "sl": -3,
            "tp": 6,
            "pnl": 0,
            "capital": self.capital,
            "simulation": True
        }
        self.logs.append(trade)
        print(json.dumps(trade, indent=2))
        
        with open('logs.json', 'w') as f:
            json.dump(self.logs, f)

if __name__ == "__main__":
    import sys
    agent = MultiStratAgent()
    if '--once' in sys.argv:
        agent.run_once()
    else:
        print("Run with --once for GitHub Actions")
